@startuml
left to right direction
skinparam packageStyle rectangle

actor "Гость сайта" as Guest

rectangle "Tutu.ru" {
  usecase "UC-01\nПостроить маршрут\n(откуда/куда/дата)" as UC01
  usecase "UC-02\nИзменить параметры\nмаршрута и дату" as UC02
  usecase "UC-03\nПереключиться между\nсервисами в шапке" as UC03
  usecase "UC-04\nПерейти в справочную\nи открыть статью" as UC04
  usecase "UC-05\nЗаполнить форму\nпоиска отелей" as UC05
  usecase "UC-06\nПодписаться на\nemail-рассылку" as UC06
  usecase "UC-07\nОбработать ошибки\nформы подписки" as UC07
  usecase "UC-08\nВернуться на главную\nпосле навигации" as UC08
}

Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04
Guest --> UC05
Guest --> UC06
Guest --> UC07
Guest --> UC08

UC02 ..> UC01 : <<extend>>
UC07 ..> UC06 : <<extend>>
UC08 ..> UC03 : <<extend>>
@enduml
