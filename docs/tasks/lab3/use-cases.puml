@startuml
left to right direction
skinparam packageStyle rectangle

actor "Гость сайта" as Guest

rectangle "Tutu.ru" {
  usecase "Просмотреть сервисный\nкаталог и ссылки\nв шапке" as UC1
  usecase "Перейти в\nсправочный раздел" as UC2
  usecase "Изучить идеи\nдля поездок" as UC3
  usecase "Изучить FAQ\nи базу знаний" as UC4
  usecase "Просмотреть\nФишки Туту" as UC5
  usecase "Ввести направление\nпоиска отеля" as UC6
  usecase "Заполнить форму\nподписки" as UC7
  usecase "Открыть политику\nобработки данных" as UC8
}

Guest --> UC1
Guest --> UC2
Guest --> UC3
Guest --> UC4
Guest --> UC5
Guest --> UC6
Guest --> UC7
Guest --> UC8
@enduml
